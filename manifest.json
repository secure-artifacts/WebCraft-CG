{
    "manifest_version": 3,
    "name": "WebCraft 网页工坊",
    "version": "1.7.2",
    "description": "网页采集、截图整理、翻译、录屏和 YouTube 辅助工具台",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "clipboardRead",
        "downloads",
        "debugger",
        "tabCapture",
        "contextMenus"
    ],
    "host_permissions": [
        "https://translate.googleapis.com/*",
        "https://api.deepl.com/*",
        "https://api-free.deepl.com/*",
        "https://img.youtube.com/*",
        "https://*.youtube.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "WebCraft 网页工坊",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "options_page": "options.html",
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "jspdf.umd.min.js",
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "commands": {
        "quick-capture": {
            "suggested_key": {
                "default": "Ctrl+Shift+S",
                "mac": "Command+Shift+S"
            },
            "description": "截图 (当前可视区域)"
        },
        "toggle-collector-canvas": {
            "suggested_key": {
                "default": "Ctrl+Q",
                "mac": "Command+Shift+Y"
            },
            "description": "打开/关闭采集画布"
        }
    }
}
